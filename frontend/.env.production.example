# 海底世界前端环境变量配置 - 生产环境
# 文件名: .env.production
# 用于: npm run build

# ==================== API 配置 ====================
# 后端 API 基础 URL
VITE_API_BASE_URL=https://api.seaworld.app/api

# ==================== 应用配置 ====================
# 应用名称
VITE_APP_NAME=海底世界

# 应用版本
VITE_APP_VERSION=1.0.0

# ==================== 功能开关 (可选) ====================
# 是否启用离线模式
# VITE_ENABLE_OFFLINE=true

# 是否显示调试信息
# VITE_ENABLE_DEBUG=false

# ==================== 第三方服务 (可选) ====================
# Google Analytics ID (如果需要)
# VITE_GA_ID=G-XXXXXXXXXX

# Sentry DSN (错误监控，如果需要)
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ==================== 安全提示 ====================
# 1. 前端环境变量会打包到生产代码中
# 2. 不要在此文件中存储敏感密钥或 Token
# 3. 所有变量必须以 VITE_ 开头才能被访问
# 4. 构建后的文件会暴露这些值给用户
