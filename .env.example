# 生产环境配置文件模板
# 使用方法:
#   1. 复制此文件为 .env
#      cp .env.example .env
#   2. 修改下面的所有值为生产环境的真实配置
#   3. 确保 .env 文件权限为 600 (只有所有者可读写)
#      chmod 600 .env
#
# 警告: 此文件包含敏感信息，绝不能提交到 Git！

# ===== 数据库配置 =====
DB_URL=jdbc:postgresql://localhost:5432/seaworld
DB_USERNAME=seaworld_prod
DB_PASSWORD=your_strong_database_password_here

# ===== JWT 密钥 =====
# 生成方法: openssl rand -base64 64
JWT_SECRET=your_production_jwt_secret_at_least_64_chars_long_generated_by_openssl

# ===== 邮件服务配置 =====
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your-production-email@qq.com
MAIL_PASSWORD=your_qq_email_authorization_code
MAIL_FROM=your-production-email@qq.com

# ===== 应用配置 =====
# 前端域名（用于邮件中的链接和 CORS）
FRONTEND_URL=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ===== Spring 配置 =====
SPRING_PROFILES_ACTIVE=prod

# ===== 服务器配置 =====
SERVER_PORT=8080

# ===== 日志配置 =====
# 可选: 如果需要自定义日志路径
# LOGGING_FILE_PATH=/var/log/seaworld

# ===== 性能配置 =====
# 数据库连接池（可选，有默认值）
# HIKARI_MAX_POOL_SIZE=10
# HIKARI_MIN_IDLE=5

# ===== 监控配置 =====
# Actuator endpoints（生产环境建议禁用或限制访问）
# MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
